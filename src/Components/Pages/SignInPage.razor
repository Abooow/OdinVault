@page "/auth/sign-in"
@inject AccountManager AccountManager
@inject NavigationManager NavigationManager

<PageTitle>Sign In</PageTitle>

<div class="main-content py-4">
    <div class="d-flex align-center justify-center">
        <span class="font-code font-subtitle">ODIN</span>
        <Icon Path="@Icons.Logo" Color="var(--color-primary)" Size="50" />
        <span class="font-code font-subtitle">VAULT</span>
    </div>
    <div class="logo-shadow pa-6 mt-1"></div>

    <div class="content-centered" style="margin-top: clamp(1rem, 20vh, 10rem);">
        <div class="bg-light rounded-md shadow-md pa-3 mx-3" style="width: min(400px, 100%);">
            <h1>Sign In</h1>
            
            <div class="mt-3">
                <p class="text-small text-dark">File</p>
                <input class="input" @bind="file" @bind:event="oninput" />
            </div>
            
            <button class="btn w-100 mt-5" @onclick="SignIn" disabled="@(!CanSignIn())">Sign In</button>
            <p class="mt-3">Don't have a file? <a href="/auth/register">Create One</a></p>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    public required SnackbarProvider SnackbarProvider { get; set; }
    
    private string? file;

    private async Task SignIn()
    {
        var result = await AccountManager.SignInSanitizedAsync(file!);
        if (!result.Succeeded)
        {
            SnackbarProvider.Add(Severity.Error, result.Message!);
            return;
        }
        
        NavigationManager.NavigateTo("/");
    }
    
    private bool CanSignIn()
    {
        return !string.IsNullOrWhiteSpace(file);
    }
}