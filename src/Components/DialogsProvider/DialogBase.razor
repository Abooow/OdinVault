@implements IDisposable

@if (IsVisible)
{
    @ChildContent
}

@code {
    [CascadingParameter]
    public DialogInstance? DialogInstance { get; set; }

    [CascadingParameter]
    public required DialogProvider DialogProvider { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool IsVisible
    {
        get;
        set
        {
            if (value == field)
                return;

            field = value;
            IsVisibleChanged.InvokeAsync(value);
        }
    } = true;

    [Parameter]
    public EventCallback<bool> IsVisibleChanged { get; set; }

    protected override void OnInitialized()
    {
        if (DialogInstance is null)
            DialogInstance = DialogProvider.Show<DialogBase>();
    }

    public void Dispose()
    {
        DialogInstance?.Cancel();
    }
}