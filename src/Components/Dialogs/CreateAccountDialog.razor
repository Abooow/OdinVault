<Dialog Width="450">
    <DialogContent>
        <div>
            <p class="text-small text-dark">Site Url/App*</p>
            <input class="input" @bind="domain" @bind:event="oninput" />
        </div>
        
        <div class="mt-3">
            <p class="text-small text-dark">Username/Email*</p>
            <input class="input" @bind="username" @bind:event="oninput" />
        </div>
        
        <div class="mt-3">
            <p class="text-small text-dark">Password</p>
            <input class="input" @bind="password" @bind:event="oninput" />
        </div>
        
        <div class="mt-3">
            <p class="text-small text-dark">Notes</p>
            <textarea class="input" rows="2" style="resize: vertical; min-height: 2em; max-height: 10em;" @bind="notes" @bind:event="oninput"></textarea>
        </div>
    </DialogContent>

    <DialogActions>
        <button class="btn btn-outlined" @onclick="DialogInstance.Cancel">Cancel</button>
        <button class="btn" @onclick="Create" disabled="@(!CanCreate())">Create</button>
    </DialogActions>
</Dialog>

@code {
    [CascadingParameter]
    public required DialogInstance DialogInstance { get; set; }

    private string? domain;
    private string? username;
    private string? password;
    private string? notes;

    private void Create()
    {
        var account = new AccountRecord()
        {
            Domain = domain!,
            Username = username!,
            Password = password,
            Notes = notes
        };
        
        DialogInstance.Close(account);
    }
    
    private bool CanCreate()
    {
        return !string.IsNullOrWhiteSpace(domain) && !string.IsNullOrWhiteSpace(username);
    }
}