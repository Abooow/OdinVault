@inject AccountManager AccountManager

<Dialog Width="450">
    <DialogContent>
        <p class="mb-2">Change Name</p>
        <div>
            <p class="text-small text-dark">Current Name</p>
            <input class="input" value="@Path.GetFileNameWithoutExtension(AccountManager.GetFilePath())" readonly disabled />
        </div>

        <div class="mt-3">
            <p class="text-small text-dark">New Name</p>
            <input class="input" @bind="newName" @bind:event="oninput" />
        </div>

        <p class="mt-4 mb-2">Change Password</p>
        <div>
            <p class="text-small text-dark">Current Password</p>
            <input class="input" @bind="currentPassword" @bind:event="oninput" type="password" />
        </div>

        <div class="mt-3">
            <p class="text-small text-dark">New Password</p>
            <input class="input" @bind="newPassword" @bind:event="oninput" type="password" />
        </div>
    </DialogContent>

    <DialogActions>
        <button class="btn btn-outlined" @onclick="DialogInstance.Cancel">Cancel</button>
        <button class="btn" @onclick="Update" disabled="@(!CanUpdate())">Update</button>
    </DialogActions>
</Dialog>

@code {
    [CascadingParameter]
    public required DialogInstance DialogInstance { get; set; }

    [CascadingParameter]
    public required SnackbarProvider SnackbarProvider { get; set; }
    
    private string? newName;
    private string? currentPassword;
    private string? newPassword;

    private async Task Update()
    {
        var result = await AccountManager.UpdateFileSanitizedAsync(newName, currentPassword, newPassword);
        if (!result.Succeeded)
        {
            SnackbarProvider.Add(Severity.Error, result.Message!);
            return;
        }
        
        SnackbarProvider.Add(Severity.Info, "Successfully updated file.");
        DialogInstance.Close();
    }

    private bool CanUpdate()
    {
        return !string.IsNullOrWhiteSpace(newName) && newName != Path.GetFileNameWithoutExtension(AccountManager.GetFilePath()) || !string.IsNullOrWhiteSpace(currentPassword) && !string.IsNullOrWhiteSpace(currentPassword);
    }
}